# ============================================================
# Tactician AI Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit your .env file to git!

# Google Gemini API Key (for AI analysis)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# RapidAPI Key (for Cricbuzz live match data & player stats)
# Get from: https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
# IMPORTANT: You must subscribe to the free tier!
RAPID_API_KEY=your_rapidapi_key_here

# ElevenLabs API Key (for premium AI voice - optional, browser speech is fallback)
# Get from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ElevenLabs Voice ID (optional, defaults to a preset voice)
ELEVENLABS_VOICE_ID=IX4AgWzTnD6q0cNvHqvK

# CORS Allowed Origins (comma-separated, for production deployment)
# For dev: http://localhost:3000,http://localhost:5173
# For prod: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
